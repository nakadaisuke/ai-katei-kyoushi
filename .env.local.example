NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel AI SDK 経由でAIヒント・再解説を生成する。プロバイダーを変える場合は
# AI_PROVIDER / AI_MODEL を変更し、対応するAPIキー（例: OPENAI_API_KEY）を設定する。
# 対応の追加はsrc/lib/ai/model.tsのswitch文に1ケース足すだけでよい。
AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=
